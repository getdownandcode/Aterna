# Clerk
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Razorpay (client-safe publishable key)
EXPO_PUBLIC_RAZORPAY_KEY_ID=

# Razorpay (server-side only — DO NOT expose in client)
RAZORPAY_KEY_SECRET=

# Gemini (server-side only — DO NOT expose in client)
GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_API_KEY=

# Mock Payments (set to true for Expo Go / simulator, false for dev builds)
EXPO_PUBLIC_USE_MOCK_PAYMENTS=true
